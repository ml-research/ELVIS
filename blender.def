Bootstrap: docker
From: ubuntu:22.04

%post
    apt-get update && apt-get install -y --no-install-recommends \
        wget xz-utils ca-certificates \
        libx11-6 libxext6 libxrender1 libxi6 libxxf86vm1 \
        libsm6 libice6 libxkbcommon0 libgl1-mesa-glx libegl1 \
        libxfixes3 libxrandr2 libxinerama1 libxcursor1 \
        python3 python3-pip \
        && rm -rf /var/lib/apt/lists/*

    # Download and install portable Blender
    cd /opt && \
    wget -q https://mirror.clarkson.edu/blender/release/Blender4.2/blender-4.2.0-linux-x64.tar.xz && \
    tar xf blender-4.2.0-linux-x64.tar.xz && \
    rm blender-4.2.0-linux-x64.tar.xz && \
    ln -s /opt/blender-4.2.0-linux-x64/blender /usr/local/bin/blender

    # Install compatible Python packages (avoid system numpy/scipy conflict)
    pip3 install --no-cache-dir --ignore-installed \
        "numpy>=1.24,<2.0" \
        "scipy>=1.10" \
        matplotlib Pillow tqdm rtpt

%environment
    export PATH=/opt/blender-4.2.0-linux-x64:$PATH

%runscript
    exec blender "$@"

%labels
    Author ELVIS-3D
    Description Blender 4.2 for CLEVR 3D scene rendering
